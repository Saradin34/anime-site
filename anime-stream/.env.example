# ============================================================
# Firebase configuration
# ============================================================
# Возьмите эти значения из консоли Firebase:
# https://console.firebase.google.com → ваш проект → Project Settings
# → раздел "Your apps" → Web app → "SDK setup and configuration"
# → выберите "Config" — там будут все эти ключи.
#
# Если оставите эти поля пустыми — сайт будет работать в mock-режиме
# (регистрация и вход через localStorage, без облака).
# ============================================================

VITE_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890
# measurementId опционален (только для Analytics). Формат: G-XXXXXXXXXX
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================================
# HiAnime / Aniwatch API (опционально)
# ============================================================
# По умолчанию используется собственный прокси на /api/aniwatch/*
# Если хотите указать внешний инстанс — впишите его URL без слэша в конце.
# Например: VITE_ANIWATCH_BASE=https://my-aniwatch.vercel.app
VITE_ANIWATCH_BASE=

# Включить / выключить HiAnime агрегатор (true/false). По умолчанию true.
VITE_ENABLE_HIANIME=true
